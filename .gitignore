# --- Environment - never commit real keys ------------------------
.env

# --- User generated data - never commit --------------------------
output/*.jsonl
output/*.json
output/*.txt
output/*.tmp

# --- Uploaded vaults - user private data -------------------------
uploads/

# --- Trained models - too large for git --------------------------
models/*.gguf
models/*.bin
models/*.safetensors
models/*.pt
models/*.pth

# --- Training artifacts ------------------------------------------
training/checkpoints/
training/__pycache__/

