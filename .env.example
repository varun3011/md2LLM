# ownLLM Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git - it is in .gitignore

# -- Required for training data generation ------------------------
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# -- Required only for gated HuggingFace models -------------------
# Needed for: Llama 3.2, Mistral
# NOT needed for: Phi-3, Qwen
# Get your token at: https://huggingface.co/settings/tokens
# Then accept the model license at huggingface.co/<model-name>
# HF_TOKEN=hf_your_token_here

# -- Optional - use Ollama instead of OpenAI for data generation --
# Set model to ollama/llama3.2 in the UI to use local generation
# No API key needed when using Ollama
